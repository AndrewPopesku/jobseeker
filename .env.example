# Google ADK / Gemini
GOOGLE_API_KEY=your_gemini_api_key_here

# Telegram bot
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-from-botfather
TELEGRAM_USER_ID=123456789   # your numeric user ID — get it from @userinfobot

# Google Drive — ID of the folder where CVs will be uploaded
